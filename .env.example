# Cuhibot Environment Configuration Template
# Copy this file to .env and fill in your actual values

# ============================================================================
# TELEGRAM BOT CONFIGURATION
# ============================================================================
# Get your bot token from @BotFather on Telegram
BOT_TOKEN="your_bot_token_here"

# Comma-separated list of admin user IDs
ADMIN_IDS="your_admin_id_here"

# Comma-separated list of allowed user IDs (leave empty to allow all)
ALLOWED_USERS=""

# ============================================================================
# SECURITY
# ============================================================================
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
COOKIE_ENCRYPTION_KEY="your_32_byte_encryption_key_here"

# ============================================================================
# DATA STORAGE
# ============================================================================
DATA_ROOT="./data"
COOKIES_ROOT="./cookies"

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================
PORT="8080"
PUBLIC_DOMAIN="your_domain_here"
RAILWAY_PUBLIC_DOMAIN=""

# ============================================================================
# CORS CONFIGURATION (Production)
# ============================================================================
# Comma-separated list of allowed origins for production
CORS_ALLOWED_ORIGINS=""

# ============================================================================
# OPTIONAL SETTINGS
# ============================================================================
# Set to 1 to skip embedded server (if running server.py separately)
SKIP_EMBEDDED_SERVER="0"

# Environment mode (development, production)
ENV="production"

# Enable debug mode (0 or 1)
DEBUG="0"

# ============================================================================
# SOCIAL MEDIA COOKIES
# ============================================================================
# NOTE: Do NOT store cookies in environment variables!
# Instead, upload cookie files to the cookies/_global/ directory
# or use the /cookies command in the bot to upload per-user cookies.
#
# Cookie files should be in Netscape format and will be automatically
# encrypted when the bot starts.

{
  "appId": "com.cuhibot.app",
  "appName": "Cuhi",
  "webDir": "www",
  "android": {
    "allowMixedContent": true
  },
  "server": {
    "androidScheme": "https",
    "cleartext": true,
    "hostname": "localhost"
  },
  "plugins": {
    "SplashScreen": {
      "launchAutoHide": true,
      "launchShowDuration": 1500,
      "backgroundColor": "#000000",
      "showSpinner": false
    },
    "Filesystem": {
      "readRequiresPermission": true
    }
  }
}
